{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://agent-forge.local/blueprint.schema.json",
  "title": "Agent Blueprint",
  "description": "Schema do blueprint de um agent autônomo (Spec Driven Agents)",
  "type": "object",
  "required": ["nome", "tipo", "objetivo", "arquitetura_cognitiva", "skills", "toolbox", "loop", "rules"],
  "properties": {
    "nome": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Nome do agent em kebab-case (ex: pos-ia-tutor)"
    },
    "nome_amigavel": {
      "type": "string",
      "description": "Nome amigável para humanos"
    },
    "descricao": {
      "type": "string",
      "description": "Descrição do que o agent faz"
    },
    "tipo": {
      "type": "string",
      "enum": ["task-based", "interactive", "goal-oriented", "autonomous"],
      "description": "Tipo de operação do agent"
    },
    "objetivo": {
      "type": "string",
      "description": "Objetivo principal do agent (orienta todas as decisões)"
    },
    "arquitetura_cognitiva": {
      "type": "string",
      "enum": ["react", "plan-and-execute", "reflection"],
      "description": "Arquitetura cognitiva: como o agent pensa"
    },
    "provider": {
      "type": "string",
      "enum": ["anthropic", "openai", "ollama", "auto"],
      "default": "auto",
      "description": "Provider do LLM (auto = usa o do ambiente)"
    },
    "modelo": {
      "type": "string",
      "description": "Modelo específico (ex: claude-3-5-sonnet, gpt-4o, llama3)"
    },
    "contrato_saida": {
      "type": "object",
      "description": "Formato esperado da saída final",
      "properties": {
        "formato": { "type": "string", "enum": ["json", "markdown", "texto"] },
        "campos_obrigatorios": { "type": "array", "items": { "type": "string" } }
      }
    },
    "loop": {
      "type": "object",
      "required": ["max_iteracoes"],
      "properties": {
        "max_iteracoes": { "type": "integer", "minimum": 1, "maximum": 50 },
        "tempo_max_segundos": { "type": "integer", "minimum": 1 },
        "tokens_max": { "type": "integer", "minimum": 100 },
        "criterios_parada": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["objetivo_alcancado", "limite_etapas", "falta_progresso", "tempo_max", "tokens_max", "interrupcao_externa"]
          }
        }
      }
    },
    "skills": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["nome", "descricao", "entrada", "saida"],
        "properties": {
          "nome": { "type": "string" },
          "descricao": { "type": "string" },
          "entrada": { "type": "object", "description": "Schema dos parâmetros de entrada" },
          "saida": { "type": "object", "description": "Schema da saída esperada" },
          "tipo_implementacao": {
            "type": "string",
            "enum": ["mock", "rest", "database", "mcp"],
            "default": "mock"
          },
          "configuracao": { "type": "object", "description": "Config do adapter (URL, query, etc.)" }
        }
      }
    },
    "toolbox": {
      "type": "array",
      "description": "Lista de skills permitidas (subconjunto de skills)",
      "items": { "type": "string" }
    },
    "rules": {
      "type": "object",
      "properties": {
        "limites_ferramenta": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ferramenta": { "type": "string" },
              "max_chamadas": { "type": "integer" }
            }
          }
        },
        "acoes_com_confirmacao": {
          "type": "array",
          "items": { "type": "string" }
        },
        "obrigatorias": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Ações que DEVEM ocorrer antes de finalizar"
        },
        "proibidas": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "curta": { "type": "boolean", "default": true },
        "longa": { "type": "boolean", "default": false },
        "episodica": { "type": "boolean", "default": false },
        "contextual": { "type": "boolean", "default": false },
        "limite_registros": { "type": "integer", "default": 100 },
        "embedding_model": { "type": "string" }
      }
    },
    "hooks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "evento": {
            "type": "string",
            "enum": ["antes_iteracao", "depois_iteracao", "antes_tool", "depois_tool", "ao_finalizar", "ao_falhar"]
          },
          "acao": { "type": "string", "enum": ["log", "alerta", "webhook"] }
        }
      }
    },
    "metadata": {
      "type": "object",
      "properties": {
        "criado_em": { "type": "string", "format": "date-time" },
        "criado_por": { "type": "string" },
        "versao_blueprint": { "type": "string", "default": "1.0.0" },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
